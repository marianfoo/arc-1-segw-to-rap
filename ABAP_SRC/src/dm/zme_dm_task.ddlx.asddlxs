@EndUserText.label: 'UI annotations: Task'
@Metadata.layer: #CORE
annotate view ZC_DM_TASK with
{
  @UI.lineItem: [{ position: 5 }]
  TaskId;

  @UI.lineItem: [{ position: 10 }]
  Title;

  @UI.lineItem: [{ position: 15 }]
  Description;

  @UI.lineItem: [{ position: 20 }]
  Status;

  @UI.lineItem: [{ position: 30 }]
  DueDate;
}
