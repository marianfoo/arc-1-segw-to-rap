{
  "_version": "1.85.0",
  "sap.app": {
    "id": "com.demo.migration.projects.fe",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap-ux/fiori-elements-writer:lrop",
      "version": "2.8.136"
    },
    "dataSources": {
      "annotation": {
        "type": "ODataAnnotation",
        "uri": "annotations/annotation.xml",
        "settings": {
          "localUri": "annotations/annotation.xml"
        }
      },
      "mainService": {
        "uri": "/sap/opu/odata4/sap/zui_dm_projects_o4/srvd/sap/zui_dm_projects_o4/0001/",
        "type": "OData",
        "settings": {
          "annotations": [
            "annotation"
          ],
          "localUri": "localService/mainService/metadata.xml",
          "odataVersion": "4.01"
        }
      }
    },
    "crossNavigation": {
      "inbounds": {
        "intent1": {
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          },
          "semanticObject": "demodmprojectsfe",
          "action": "display",
          "title": "{{appTitle}}",
          "subTitle": "{{appDescription}}",
          "icon": ""
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.147.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "com.demo.migration.projects.fe.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": []
    },
    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": ":?query:",
          "name": "ProjectList",
          "target": "ProjectList"
        },
        {
          "pattern": "Project({key}):?query:",
          "name": "ProjectObjectPage",
          "target": "ProjectObjectPage"
        },
        {
          "pattern": "Project({key})/Task({key2}):?query:",
          "name": "TaskObjectPage",
          "target": "TaskObjectPage"
        },
        {
          "pattern": "Project({key})/Task({key2})/TimeEntry({key3}):?query:",
          "name": "TimeEntryObjectPage",
          "target": "TimeEntryObjectPage"
        }
      ],
      "targets": {
        "ProjectList": {
          "type": "Component",
          "id": "ProjectList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/Project",
              "variantManagement": "Page",
              "navigation": {
                "Project": {
                  "detail": {
                    "route": "ProjectObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable"
                  }
                }
              }
            }
          }
        },
        "ProjectObjectPage": {
          "type": "Component",
          "id": "ProjectObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/Project",
              "navigation": {
                "Task": {
                  "detail": {
                    "route": "TaskObjectPage"
                  }
                }
              }
            }
          }
        },
        "TaskObjectPage": {
          "type": "Component",
          "id": "TaskObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/Project/Task",
              "navigation": {
                "_TimeEntries": {
                  "detail": {
                    "route": "TimeEntryObjectPage"
                  }
                }
              }
            }
          }
        },
        "TimeEntryObjectPage": {
          "type": "Component",
          "id": "TimeEntryObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/Project/Task/TimeEntry"
            }
          }
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  },
  "sap.fe": {
    "app": {
      "enableLazyLoading": true
    }
  }
}
