{
  "mcpServers": {
    "arc1": {
      "command": "node",
      "args": [
        "/Users/example-user/DEV/arc-1/dist/index.js",
        "--url", "http://example-s4hana.local:50000",
        "--user", "DEMOUSER",
        "--client", "001",
        "--profile", "developer",
        "--insecure"
      ],
      "env": {
        "SAP_PASSWORD": "CHANGE_ME",
        "SAP_LINT_BEFORE_WRITE": "false"
      }
    },
    "sap-docs": {
      "url": "https://mcp-sap-docs.example.com/mcp"
    },
    "sapui5-mcp-server": {
      "command": "npx",
      "args": ["-y", "@sap/mcp-server-sapui5@latest"]
    }
  }
}
