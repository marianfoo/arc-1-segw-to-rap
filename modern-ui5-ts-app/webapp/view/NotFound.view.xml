<mvc:View
	controllerName="com.demo.migration.projects.modern.controller.NotFound"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc">
	<Page
		title="Not Found"
		showNavButton="true"
		navButtonPress=".onNavBack">
		<content>
			<IllustratedMessage
				illustrationType="sapIllus-NoEntries"
				titleText="{i18n>notFoundText}"
				descriptionText=""
				enableDensityAwareness="false"
				enableFormattedText="false"
			/>
		</content>
	</Page>
</mvc:View>
